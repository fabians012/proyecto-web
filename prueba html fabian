<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Sitio Web</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="estilos.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">restaurante</a>

            <ul class="navbar-nav">
                <li class="nav-item mx-3"><a class="nav-link" href="#inicio">inicio</a></li>

                <li class="nav-item mx-3"><a class="nav-link" href="#servicios">menu</a></li>

                <li class="nav-item mx-3"><a class="nav-link" href="#reserva">reserva</a></li>

                <li class="nav-item mx-3"><a class="nav-link" href="#contacto">Contacto</a></li>

            </ul>
        </div>
    </nav>

    <section id="inicio" class="container mt-4">

    <h1 class="text-center">Bienvenido al restaurante buffet rancagua </h1>

    <img src="https://tse3.mm.bing.net/th/id/OIP.koJTY--BEFRUvyK7ouRNbAHaEK?rs=1&pid=ImgDetMain&o=7&rm=3"
    class="img-fluid mx-auto d-block mi-borde">

    <p class="mt-3 texto-morado text-center">
        en nuestro restaurante ofrecemos comida casera preparada con los ingredientes frescos al igual que tenemos un ambiente y lugar comodo para estar en familia y amigos
    </p>

    <div class="alert alert-primary text-center">
    ven a visitarnos y prueba nuestro mejor buffet 
    </div>

</section>

<section id="menu" class="container mt-5 seccion-gris">

    <h2>menu</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Buffet de Carnes</h5>
                    <p class="card-text">variedad de carnes asadas</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-tittle">buffet de pasta</h5>
                    <p class="card-text">diferentes tipos de pasta con salsa a tu eleccion</p>
                </div>
            </div>
        </div>

    </div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-tittle">buffet de postres</h5>
                <p class="card-text">gran variedad de dulces y postres</p>
            </div>
        </div>
    </div>
</div>

</section>


<section id="reserva" class="container mt-5">

    <h2>reserva de mesa</h2><h2>

    <form>
        <input type="text" class="form-control mb-2" placeholder="Nombre" required>
        <input type="number" class="form-control mb-2" placeholder="Número de personas" required>
        <input type="email" class="form-control mb-2" placeholder="Correo" required>
        <input type="date" class="form-control mb-2" required>
        <input type="tel" class="form-control mb-2" placeholder="Teléfono" required>
        <input type="time" class="form-control mb-2" required>

        <select class="form-control mb-2" required>
            <option value="">Selecciona ubicación</option>
            <option>Interior</option>
            <option>Terraza</option>
        </select>

        <button class="btn btn-primary">Reservar</button>

    </form>

</section>

<section id="contacto" class="container mt-5">

    <h2>contacto</h2>

    <form>
        <input type="text" class="form-control mb-2" placeholder="nombre" required>

        <input type="email" class="form-control mb-2" placeholder="correo" required>

        <textarea class="form-control mb-2" placeholder="mensaje" required></textarea>

        <button class="btn btn-success">enviar</button>

    </form>

</section>


<footer class="bg-dark text-white text-center mt-5 p-3">

    <p>fabian ulises rodrigo villalobos</p>

    <p>https://github.com/fabians012/proyecto-web/blob/main/prueba%20html%20fabian</p>

    </footer>

</body>
</html>
